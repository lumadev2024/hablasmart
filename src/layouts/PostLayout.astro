---
/**
 * PostLayout.astro
 * Layout per i singoli articoli del blog.
 * Riceve i dati dal frontmatter tramite props di CollectionEntry.
 */
import BaseLayout from './BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
  readingTime: number;
}

const { post, readingTime } = Astro.props;
const {
  title,
  description,
  pubDate,
  updatedDate,
  category,
  tags = [],
  heroImage,
  heroImageAlt,
  author,
} = post.data;

const dateFormatted = pubDate.toLocaleDateString('it-IT', {
  day: '2-digit',
  month: 'long',
  year: 'numeric',
});

const dateISO = pubDate.toISOString().slice(0, 10);

// JSON-LD per l'articolo
const articleSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  datePublished: pubDate.toISOString(),
  dateModified: (updatedDate ?? pubDate).toISOString(),
  author: { '@type': 'Person', name: author ?? 'HablaSmart' },
  publisher: {
    '@type': 'Organization',
    name: 'HablaSmart',
    url: Astro.site?.href,
  },
  inLanguage: 'it-IT',
  url: new URL(Astro.url.pathname, Astro.site).href,
  ...(heroImage ? { image: new URL(heroImage, Astro.site).href } : {}),
});
---

<BaseLayout
  title={title}
  description={description}
  ogImage={heroImage ?? '/og-image.jpg'}
  ogType="article"
  pubDate={pubDate}
>

  <!-- Schema JSON-LD articolo -->
  <script type="application/ld+json" set:html={articleSchema} slot="head" />

  <!-- ============================================================
       HERO ARTICOLO
  ============================================================ -->
  <section class="post-hero">
    <div class="container post-hero-inner">

      <!-- Breadcrumb -->
      <nav class="post-breadcrumb" aria-label="Percorso navigazione">
        <ol>
          <li><a href="/">Home</a></li>
          <li aria-hidden="true">→</li>
          <li><a href="/articoli/">Articoli</a></li>
          <li aria-hidden="true">→</li>
          <li aria-current="page">{title}</li>
        </ol>
      </nav>

      <!-- Meta -->
      <div class="post-hero-meta">
        <a href={`/articoli/?categoria=${encodeURIComponent(category)}`}
           class="post-category"
           aria-label={`Categoria: ${category}`}>
          {category}
        </a>
        <time class="post-date" datetime={dateISO}>{dateFormatted}</time>
        <span class="post-read-time">⏱ {readingTime} min di lettura</span>
      </div>

      <!-- Titolo -->
      <h1 class="post-hero-title" style={`view-transition-name: post-title-${post.slug}`}>{title}</h1>
      <p class="post-hero-desc">{description}</p>

      <!-- Autore -->
      <div class="post-author">
        <div class="post-author-avatar" aria-hidden="true">
          {(author ?? 'H').charAt(0).toUpperCase()}
        </div>
        <span class="post-author-name">{author ?? 'HablaSmart'}</span>
      </div>

    </div>
  </section>

  <!-- ============================================================
       IMMAGINE COPERTINA (se presente)
  ============================================================ -->
  {heroImage && (
    <div class="post-cover">
      <div class="container">
        <img
          src={heroImage}
          alt={heroImageAlt ?? title}
          loading="eager"
          decoding="async"
          class="post-cover-img"
          style={`view-transition-name: post-image-${post.slug}`}
        />
      </div>
    </div>
  )}

  <!-- ============================================================
       CORPO ARTICOLO
  ============================================================ -->
  <article class="post-body" aria-labelledby="post-heading">
    <div class="container">
      <div class="prose">
        <slot />
      </div>

      <!-- Tag -->
      {tags.length > 0 && (
        <div class="post-tags" role="list" aria-label="Tag articolo">
          {tags.map(tag => (
            <a
              href={`/articoli/?tag=${encodeURIComponent(tag)}`}
              class="post-tag"
              role="listitem"
            >
              #{tag}
            </a>
          ))}
        </div>
      )}
    </div>
  </article>

  <!-- ============================================================
       SEZIONE: ALTRI ARTICOLI
  ============================================================ -->
  <section class="post-cta-section" aria-label="Continua a leggere">
    <div class="container post-cta-inner">
      <p class="post-cta-label">Hai finito? C'è altro per te →</p>
      <a href="/articoli/" class="btn btn-primary btn-lg">
        Esplora tutti gli articoli
      </a>
    </div>
  </section>

</BaseLayout>

<style>
/* ============================================================
   POST HERO
============================================================ */
.post-hero {
  padding: var(--space-20) 0 var(--space-12);
  background: linear-gradient(to bottom, var(--color-primary-light) 0%, var(--color-bg) 100%);
  position: relative;
  overflow: hidden;
}

.post-hero::before {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse at 80% 0%, rgba(244,114,182,.06), transparent 60%);
  pointer-events: none;
}

.post-hero-inner { max-width: 760px; position: relative; z-index: 1; }

/* Breadcrumb */
.post-breadcrumb { margin-bottom: var(--space-6); }
.post-breadcrumb ol {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  flex-wrap: wrap;
  font-size: var(--text-xs);
  color: var(--color-text-light);
}
.post-breadcrumb a {
  color: var(--color-primary);
  text-decoration: none;
  transition: opacity var(--transition-fast);
}
.post-breadcrumb a:hover { opacity: .75; }
.post-breadcrumb [aria-current] { color: var(--color-text-muted); }

/* Meta riga */
.post-hero-meta {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: var(--space-3);
  margin-bottom: var(--space-5);
}

.post-category {
  font-size: var(--text-xs);
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .08em;
  color: var(--color-primary);
  background: var(--color-primary-light);
  padding: 2px var(--space-3);
  border-radius: var(--radius-full);
  border: 1px solid rgba(124,58,237,.15);
  text-decoration: none;
  transition: background var(--transition-fast);
}
.post-category:hover { background: rgba(124,58,237,.2); }

.post-date, .post-read-time {
  font-size: var(--text-xs);
  color: var(--color-text-light);
}

/* Titolo */
.post-hero-title {
  font-family: var(--font-serif);
  font-size: clamp(var(--text-2xl), 5vw, var(--text-4xl));
  line-height: 1.15;
  color: var(--color-text);
  letter-spacing: -0.03em;
  margin-bottom: var(--space-5);
}

.post-hero-desc {
  font-size: var(--text-md);
  color: var(--color-text-muted);
  line-height: 1.75;
  margin-bottom: var(--space-8);
  max-width: 660px;
}

/* Autore */
.post-author {
  display: flex;
  align-items: center;
  gap: var(--space-3);
}
.post-author-avatar {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background: var(--color-primary);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
  font-size: var(--text-md);
  font-family: var(--font-serif);
  flex-shrink: 0;
}
.post-author-name { font-size: var(--text-sm); font-weight: 600; color: var(--color-text); }

/* ============================================================
   COVER IMAGE
============================================================ */
.post-cover { padding: 0 0 var(--space-12); }
.post-cover-img {
  width: 100%;
  max-height: 480px;
  object-fit: cover;
  border-radius: var(--radius-2xl);
  box-shadow: var(--shadow-xl);
}

/* ============================================================
   CORPO ARTICOLO
============================================================ */
.post-body { padding: var(--space-12) 0 var(--space-16); }

/* Tag */
.post-tags {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-2);
  margin-top: var(--space-12);
  padding-top: var(--space-8);
  border-top: 1px solid var(--color-border);
  max-width: 720px;
  margin-left: auto;
  margin-right: auto;
}
.post-tag {
  display: inline-block;
  font-size: var(--text-xs);
  font-weight: 500;
  color: var(--color-text-muted);
  background: var(--color-border-light);
  padding: var(--space-1) var(--space-3);
  border-radius: var(--radius-full);
  text-decoration: none;
  transition: all var(--transition-fast);
}
.post-tag:hover { background: var(--color-primary-light); color: var(--color-primary); }

/* ============================================================
   CTA
============================================================ */
.post-cta-section {
  background: linear-gradient(135deg, var(--color-primary-light), var(--color-secondary-light));
  padding: var(--space-16) 0;
}
.post-cta-inner { text-align: center; }
.post-cta-label {
  font-size: var(--text-md);
  color: var(--color-text-muted);
  margin-bottom: var(--space-6);
}

/* ============================================================
   RESPONSIVE
============================================================ */
@media (max-width: 768px) {
  .post-hero { padding: var(--space-12) 0 var(--space-8); }
  .post-hero-title { font-size: var(--text-2xl); }
  .post-hero-meta { gap: var(--space-2); }
}
</style>
