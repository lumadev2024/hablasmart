---
/**
 * src/pages/risorse/index.astro
 * Sezione Risorse – Ebook in vendita su Gumroad.
 */
import BaseLayout from '@/layouts/BaseLayout.astro';

const ebooks = [
  {
    id: 1,
    titolo: "Il Metodo della Comunicazione Persuasiva",
    descrizione: "Scopri le tecniche psicologiche che rendono ogni messaggio irresistibile. Dalla struttura del discorso alle parole chiave che attivano l'azione.",
    prezzo: "€ 19",
    tag: "Comunicazione",
    pagine: "120 pagine",
    formato: "PDF",
    copertina: "/images/ebook-comunicazione.jpg",
    gumroadUrl: "https://gumroad.com/l/SOSTITUISCI-LINK-1",
    inEvidenza: true,
  },
  {
    id: 2,
    titolo: "Marketing con le Parole",
    descrizione: "Una guida pratica per creare copy che vende: dalla headline alla call to action, impara a scrivere testi che convertono.",
    prezzo: "€ 15",
    tag: "Marketing",
    pagine: "90 pagine",
    formato: "PDF",
    copertina: "/images/ebook-marketing.jpg",
    gumroadUrl: "https://gumroad.com/l/SOSTITUISCI-LINK-2",
    inEvidenza: false,
  },
  {
    id: 3,
    titolo: "AI & Contenuti: La Guida Pratica",
    descrizione: "Come usare l'intelligenza artificiale per creare contenuti autentici, efficaci e su misura per il tuo pubblico.",
    prezzo: "€ 12",
    tag: "AI & Contenuti",
    pagine: "70 pagine",
    formato: "PDF",
    copertina: "/images/ebook-ai.jpg",
    gumroadUrl: "https://gumroad.com/l/SOSTITUISCI-LINK-3",
    inEvidenza: false,
  },
];
---

<BaseLayout
  title="Risorse – Ebook su Comunicazione e Marketing"
  description="Ebook pratici su comunicazione persuasiva, marketing e AI. Scaricali subito e migliora le tue competenze."
>

  <!-- HERO -->
  <section class="risorse-hero">
    <div class="container risorse-hero-inner">
      <span class="risorse-label">Risorse</span>
      <h1 class="risorse-title">Ebook per comunicare<br>e vendere meglio</h1>
      <p class="risorse-subtitle">
        Guide pratiche, scritte in italiano, per professionisti e imprenditori
        che vogliono migliorare la propria comunicazione e il proprio marketing.
      </p>
    </div>
  </section>

  <!-- GRIGLIA EBOOK -->
  <section class="ebooks-section">
    <div class="container">
      <div class="ebooks-grid">
        {ebooks.map((ebook) => (
          <article class={`ebook-card${ebook.inEvidenza ? ' ebook-card--featured' : ''}`}>
            {ebook.inEvidenza && (
              <div class="ebook-badge">In evidenza</div>
            )}

            <div class="ebook-cover">
              <div class="ebook-cover-placeholder" aria-hidden="true">
                <span class="ebook-cover-icon">📖</span>
              </div>
            </div>

            <div class="ebook-body">
              <span class="ebook-tag">{ebook.tag}</span>
              <h2 class="ebook-title">{ebook.titolo}</h2>
              <p class="ebook-desc">{ebook.descrizione}</p>

              <div class="ebook-meta">
                <span class="ebook-meta-item">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                  {ebook.pagine}
                </span>
                <span class="ebook-meta-item">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                  {ebook.formato}
                </span>
              </div>
            </div>

            <div class="ebook-footer">
              <span class="ebook-price">{ebook.prezzo}</span>
              <a
                href={ebook.gumroadUrl}
                target="_blank"
                rel="noopener noreferrer"
                class={`btn${ebook.inEvidenza ? ' btn-primary' : ' btn-outline'} btn-acquista`}
              >
                Acquista ora
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- GARANZIA / RASSICURAZIONI -->
  <section class="garanzie-section">
    <div class="container">
      <div class="garanzie-grid">
        <div class="garanzia-item">
          <div class="garanzia-icon" aria-hidden="true">⚡</div>
          <h3>Download immediato</h3>
          <p>Ricevi il file subito dopo il pagamento, direttamente nella tua email.</p>
        </div>
        <div class="garanzia-item">
          <div class="garanzia-icon" aria-hidden="true">🔒</div>
          <h3>Pagamento sicuro</h3>
          <p>Tutti i pagamenti sono gestiti da Gumroad con crittografia SSL.</p>
        </div>
        <div class="garanzia-item">
          <div class="garanzia-icon" aria-hidden="true">💳</div>
          <h3>Carte e PayPal</h3>
          <p>Puoi pagare con carta di credito, debito o PayPal.</p>
        </div>
        <div class="garanzia-item">
          <div class="garanzia-icon" aria-hidden="true">✉️</div>
          <h3>Hai domande?</h3>
          <p>Scrivimi prima di acquistare, rispondo entro 24 ore.</p>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
/* ── HERO ────────────────────────────────────────────── */
.risorse-hero {
  padding: var(--space-20) 0 var(--space-16);
  text-align: center;
}

.risorse-hero-inner {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.risorse-label {
  display: inline-block;
  font-size: var(--text-sm);
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--color-primary);
  background: var(--color-primary-light);
  padding: var(--space-1) var(--space-3);
  border-radius: var(--radius-full);
  margin-bottom: var(--space-5);
}

.risorse-title {
  font-family: var(--font-serif);
  font-size: clamp(var(--text-3xl), 5vw, var(--text-5xl));
  line-height: 1.15;
  letter-spacing: -0.02em;
  margin-bottom: var(--space-5);
  background: linear-gradient(135deg, var(--color-primary), var(--color-secondary));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.risorse-subtitle {
  font-size: var(--text-md);
  color: var(--color-text-muted);
  line-height: 1.75;
  max-width: 560px;
}

/* ── GRIGLIA EBOOK ───────────────────────────────────── */
.ebooks-section {
  padding: var(--space-8) 0 var(--space-20);
}

.ebooks-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(min(300px, 100%), 1fr));
  gap: var(--space-8);
}

/* ── CARD ────────────────────────────────────────────── */
.ebook-card {
  position: relative;
  background: var(--color-surface);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-xl);
  overflow: hidden;
  display: flex;
  flex-direction: column;
  transition: box-shadow var(--transition-base), transform var(--transition-base);
}

.ebook-card:hover {
  box-shadow: var(--shadow-xl);
  transform: translateY(-4px);
}

.ebook-card--featured {
  border-color: var(--color-primary);
  box-shadow: 0 0 0 2px var(--color-primary-light), var(--shadow-lg);
}

.ebook-badge {
  position: absolute;
  top: var(--space-4);
  right: var(--space-4);
  background: linear-gradient(135deg, var(--color-primary), var(--color-secondary));
  color: #fff;
  font-size: var(--text-xs);
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  padding: var(--space-1) var(--space-3);
  border-radius: var(--radius-full);
  z-index: 1;
}

/* Cover placeholder (sostituire con <img> quando disponibile) */
.ebook-cover {
  background: linear-gradient(135deg, var(--color-primary-light), var(--color-secondary-light));
  height: 180px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ebook-cover-icon {
  font-size: 4rem;
  line-height: 1;
  filter: grayscale(0.2);
}

/* Body */
.ebook-body {
  padding: var(--space-6);
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
}

.ebook-tag {
  display: inline-block;
  font-size: var(--text-xs);
  font-weight: 600;
  color: var(--color-primary);
  background: var(--color-primary-light);
  padding: 2px var(--space-2);
  border-radius: var(--radius-sm);
  align-self: flex-start;
}

.ebook-title {
  font-family: var(--font-serif);
  font-size: var(--text-xl);
  line-height: 1.3;
  color: var(--color-text);
}

.ebook-desc {
  font-size: var(--text-sm);
  color: var(--color-text-muted);
  line-height: 1.7;
  flex: 1;
}

.ebook-meta {
  display: flex;
  gap: var(--space-4);
  margin-top: var(--space-2);
}

.ebook-meta-item {
  display: flex;
  align-items: center;
  gap: var(--space-1);
  font-size: var(--text-xs);
  color: var(--color-text-light);
}

/* Footer */
.ebook-footer {
  padding: var(--space-4) var(--space-6) var(--space-6);
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-top: 1px solid var(--color-border-light);
  gap: var(--space-4);
}

.ebook-price {
  font-size: var(--text-xl);
  font-weight: 700;
  color: var(--color-text);
}

.btn-acquista {
  flex-shrink: 0;
}

.btn-outline {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: var(--space-2) var(--space-5);
  border-radius: var(--radius-full);
  font-size: var(--text-sm);
  font-weight: 600;
  border: 2px solid var(--color-primary);
  color: var(--color-primary);
  background: transparent;
  text-decoration: none;
  transition: background var(--transition-fast), color var(--transition-fast);
}

.btn-outline:hover {
  background: var(--color-primary);
  color: #fff;
}

/* ── GARANZIE ────────────────────────────────────────── */
.garanzie-section {
  background: var(--color-border-light);
  padding: var(--space-16) 0;
}

.garanzie-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(min(200px, 100%), 1fr));
  gap: var(--space-8);
}

.garanzia-item {
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-3);
}

.garanzia-icon {
  font-size: 2rem;
  line-height: 1;
}

.garanzia-item h3 {
  font-size: var(--text-base);
  font-weight: 700;
  color: var(--color-text);
}

.garanzia-item p {
  font-size: var(--text-sm);
  color: var(--color-text-muted);
  line-height: 1.6;
  max-width: 200px;
}

/* ── RESPONSIVE ──────────────────────────────────────── */
@media (max-width: 768px) {
  .risorse-hero { padding: var(--space-12) 0 var(--space-8); }
  .ebooks-grid { grid-template-columns: 1fr; }
  .ebook-footer { flex-direction: column; align-items: flex-start; }
  .btn-acquista { width: 100%; text-align: center; }
  .garanzie-grid { grid-template-columns: repeat(2, 1fr); }
}

@media (max-width: 480px) {
  .risorse-hero { padding: var(--space-10) 0 var(--space-6); }
  .risorse-title { font-size: var(--text-3xl); }
  .ebook-cover { height: 140px; }
  .ebook-body { padding: var(--space-4); }
  .ebook-footer { padding: var(--space-3) var(--space-4) var(--space-4); }
  .garanzie-grid { grid-template-columns: 1fr; }
  .garanzie-section { padding: var(--space-10) 0; }
}
</style>
