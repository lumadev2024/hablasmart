---
/**
 * src/pages/articoli/index.astro
 * Pagina archivio articoli con filtro per categoria via URL.
 * Il filtraggio avviene lato client (SSG compatible).
 */
import BaseLayout  from '@/layouts/BaseLayout.astro';
import PostCard    from '@/components/PostCard.astro';
import { getCollection } from 'astro:content';
import { readingTime }   from '@/utils/readingTime';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Categorie uniche per i filtri
const categories = [...new Set(allPosts.map(p => p.data.category))];

const pageTitle = 'Tutti gli articoli';
const pageDesc  = 'Esplora tutti gli articoli di HablaSmart su comunicazione, psicologia della persuasione, marketing e AI applicata ai contenuti.';
---

<BaseLayout title={pageTitle} description={pageDesc}>

  <!-- Hero archivio -->
  <section class="archive-hero">
    <div class="container">
      <header class="archive-header">
        <span class="section-label">Blog</span>
        <h1 class="archive-title">
          Tutti gli <em>articoli</em>
        </h1>
        <p class="archive-subtitle">{pageDesc}</p>
      </header>

      <!-- Filtri categoria -->
      <nav class="category-filters" aria-label="Filtra per categoria">
        <a
          href="/articoli/"
          class="cat-btn active"
          aria-current="page"
          data-filter-all
        >
          Tutti ({allPosts.length})
        </a>
        {categories.map(cat => (
          <a
            href={`/articoli/?categoria=${encodeURIComponent(cat)}`}
            class="cat-btn"
            data-filter-cat={cat}
          >
            {cat} ({allPosts.filter(p => p.data.category === cat).length})
          </a>
        ))}
      </nav>

      <!-- Badge filtro tag attivo (nascosto di default, mostrato via JS) -->
      <div class="tag-filter-active" hidden>
        <span>Tag: <strong id="active-tag-label"></strong></span>
        <a href="/articoli/" class="tag-filter-clear" aria-label="Rimuovi filtro tag">✕ Rimuovi</a>
      </div>
    </div>
  </section>

  <!-- Griglia articoli -->
  <section class="archive-grid-section" aria-label="Lista articoli">
    <div class="container">

      <div class="archive-grid" id="archive-grid">
        {allPosts.map((post, i) => (
          <div
            class="post-card-wrapper"
            data-category={post.data.category}
            data-tags={JSON.stringify(post.data.tags ?? [])}
          >
            <PostCard
              post={post}
              variant="default"
              readingTime={readingTime(post.body)}
              artIndex={i}
              delay={`${(i % 3) * 0.1}s`}
            />
          </div>
        ))}
      </div>

      <div class="archive-empty" id="archive-empty" hidden>
        <p>Nessun articolo trovato per questa categoria.</p>
        <a href="/articoli/" class="btn btn-outline">Vedi tutti gli articoli</a>
      </div>

    </div>
  </section>

  <!-- CTA newsletter -->
  <section class="archive-cta" aria-label="Iscriviti alla newsletter">
    <div class="container archive-cta-inner">
      <div>
        <h2 class="archive-cta-title">Non perderti nessun articolo.</h2>
        <p class="archive-cta-sub">Ogni venerdì, un insight diretto nella tua casella.</p>
      </div>
      <a href="/#newsletter" class="btn btn-primary btn-lg">
        Iscriviti gratis →
      </a>
    </div>
  </section>

</BaseLayout>

<script>
  function applyFilters() {
    const params   = new URLSearchParams(window.location.search);
    const catParam = params.get('categoria') ?? '';
    const tagParam = params.get('tag') ?? '';

    // Active state bottoni categoria
    const btnAll = document.querySelector<HTMLElement>('[data-filter-all]');
    if (btnAll) {
      btnAll.classList.toggle('active', !catParam);
      catParam
        ? btnAll.removeAttribute('aria-current')
        : btnAll.setAttribute('aria-current', 'page');
    }
    document.querySelectorAll<HTMLElement>('[data-filter-cat]').forEach(btn => {
      const isActive = btn.dataset.filterCat === catParam;
      btn.classList.toggle('active', isActive);
      isActive
        ? btn.setAttribute('aria-current', 'page')
        : btn.removeAttribute('aria-current');
    });

    // Badge tag
    const tagBadge = document.querySelector<HTMLElement>('.tag-filter-active');
    const tagLabel = document.getElementById('active-tag-label');
    if (tagBadge && tagLabel) {
      if (tagParam) {
        tagBadge.removeAttribute('hidden');
        tagLabel.textContent = `#${tagParam}`;
      } else {
        tagBadge.setAttribute('hidden', '');
      }
    }

    // Filtra le card
    const wrappers = document.querySelectorAll<HTMLElement>('.post-card-wrapper');
    let visible = 0;
    wrappers.forEach(wrapper => {
      const matchCat = catParam ? wrapper.dataset.category === catParam : true;
      const tags: string[] = JSON.parse(wrapper.dataset.tags || '[]');
      const matchTag = tagParam ? tags.includes(tagParam) : true;
      const show = matchCat && matchTag;
      wrapper.hidden = !show;
      if (show) visible++;
    });

    // Stato vuoto
    const grid  = document.getElementById('archive-grid');
    const empty = document.getElementById('archive-empty');
    if (grid && empty) {
      if (visible === 0) {
        grid.setAttribute('hidden', '');
        empty.removeAttribute('hidden');
      } else {
        grid.removeAttribute('hidden');
        empty.setAttribute('hidden', '');
      }
    }
  }

  applyFilters();
  window.addEventListener('popstate', applyFilters);
</script>

<style>
/* ============================================================
   ARCHIVE HERO
============================================================ */
.archive-hero {
  padding: var(--space-20) 0 var(--space-10);
  background: linear-gradient(to bottom, var(--color-primary-light) 0%, var(--color-bg) 100%);
}

.archive-header {
  text-align: center;
  margin-bottom: var(--space-10);
}

.archive-title {
  font-family: var(--font-serif);
  font-size: clamp(var(--text-3xl), 5vw, var(--text-5xl));
  line-height: 1.1;
  letter-spacing: -0.03em;
  margin-bottom: var(--space-4);
}

.archive-title em {
  font-style: italic;
  background: linear-gradient(135deg, var(--color-primary), var(--color-secondary));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.archive-subtitle {
  font-size: var(--text-md);
  color: var(--color-text-muted);
  max-width: 560px;
  margin: 0 auto;
}

/* Filtri */
.category-filters {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
  gap: var(--space-2);
}

.cat-btn {
  display: inline-block;
  padding: var(--space-2) var(--space-5);
  font-size: var(--text-sm);
  font-weight: 500;
  color: var(--color-text-muted);
  background: var(--color-surface);
  border: 1.5px solid var(--color-border);
  border-radius: var(--radius-full);
  text-decoration: none;
  transition: all var(--transition-fast);
}

.cat-btn:hover { border-color: var(--color-primary); color: var(--color-primary); background: var(--color-primary-light); }
.cat-btn.active { background: var(--color-primary); color: #fff; border-color: var(--color-primary); box-shadow: var(--shadow-primary); }

/* Tag filter badge */
.tag-filter-active {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--space-4);
  margin-top: var(--space-4);
  font-size: var(--text-sm);
  color: var(--color-text-muted);
}

.tag-filter-clear {
  display: inline-flex;
  align-items: center;
  gap: var(--space-1);
  font-size: var(--text-xs);
  font-weight: 600;
  color: var(--color-primary);
  background: var(--color-primary-light);
  padding: var(--space-1) var(--space-3);
  border-radius: var(--radius-full);
  text-decoration: none;
  transition: background var(--transition-fast);
}
.tag-filter-clear:hover { background: rgba(124,58,237,.2); }

/* ============================================================
   ARCHIVE GRID
============================================================ */
.archive-grid-section { padding: var(--space-16) 0 var(--space-32); }

.archive-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--space-8);
}

/* Tutti i post card in archivio hanno la stessa dimensione immagine */
.archive-grid :global(.post-card-image) { height: 200px; }

.archive-empty {
  text-align: center;
  padding: var(--space-24) 0;
}
.archive-empty p {
  font-size: var(--text-lg);
  color: var(--color-text-muted);
  margin-bottom: var(--space-8);
}

/* ============================================================
   ARCHIVE CTA
============================================================ */
.archive-cta {
  background: var(--color-border-light);
  padding: var(--space-16) 0;
  border-top: 1px solid var(--color-border);
}

.archive-cta-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-8);
}

.archive-cta-title {
  font-family: var(--font-serif);
  font-size: var(--text-2xl);
  font-weight: 700;
  letter-spacing: -0.02em;
  margin-bottom: var(--space-2);
}

.archive-cta-sub { font-size: var(--text-md); color: var(--color-text-muted); }

/* ============================================================
   RESPONSIVE
============================================================ */
@media (max-width: 1024px) {
  .archive-grid { grid-template-columns: repeat(2, 1fr); }
}

@media (max-width: 768px) {
  .archive-hero { padding: var(--space-12) 0 var(--space-8); }
  .archive-grid { grid-template-columns: 1fr; }
  .archive-cta-inner { flex-direction: column; text-align: center; }
  .category-filters { gap: var(--space-2); }
}
</style>
