---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PostCard   from '@/components/PostCard.astro';
import { getCollection } from 'astro:content';
import { readingTime }   from '@/utils/readingTime';

const allPosts = await getCollection('blog', ({ data }) => !data.draft && data.category === 'Gruppi');
allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const pageTitle = 'Gruppi — HablaSmart';
const pageDesc  = 'Articoli su dinamiche di gruppo, leadership comunicativa, marketing sociale e persuasione collettiva. I gruppi hanno una mente propria — impara a parlarle.';
---

<BaseLayout title={pageTitle} description={pageDesc}>

  <section class="cat-hero">
    <div class="container">
      <div class="cat-hero-inner">
        <span class="cat-label">Sezione</span>
        <h1 class="cat-title">Gruppi</h1>
        <p class="cat-subtitle">
          I gruppi hanno una mente propria — impara a parlare ad essa.
          Dinamiche collettive, leadership comunicativa e marketing sociale.
        </p>
        <div class="cat-stats">
          <span>{allPosts.length} articoli</span>
        </div>
      </div>
    </div>
  </section>

  <section class="cat-grid-section">
    <div class="container">
      {allPosts.length > 0 ? (
        <div class="cat-grid">
          {allPosts.map((post, i) => (
            <PostCard
              post={post}
              variant="default"
              readingTime={readingTime(post.body)}
              artIndex={i}
              delay={`${(i % 3) * 0.1}s`}
            />
          ))}
        </div>
      ) : (
        <div class="cat-empty">
          <p>Nessun articolo ancora pubblicato in questa sezione. Torna presto!</p>
          <a href="/articoli/" class="btn btn-outline">Vedi tutti gli articoli</a>
        </div>
      )}
    </div>
  </section>

  <section class="cat-cta">
    <div class="container cat-cta-inner">
      <div>
        <h2 class="cat-cta-title">Non perderti nessun articolo su Gruppi.</h2>
        <p class="cat-cta-sub">Ogni venerdì, un insight diretto nella tua casella.</p>
      </div>
      <a href="/#newsletter" class="btn btn-primary btn-lg">Iscriviti gratis →</a>
    </div>
  </section>

</BaseLayout>

<style>
.cat-hero {
  padding: var(--space-20) 0 var(--space-12);
  background: var(--color-gruppi-light);
  border-bottom: 3px solid var(--color-gruppi);
}

.cat-hero-inner {
  max-width: 680px;
}

.cat-label {
  display: inline-block;
  font-size: var(--text-xs);
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .14em;
  color: var(--color-gruppi);
  background: rgba(8,145,178,.12);
  padding: var(--space-1) var(--space-3);
  border-radius: var(--radius-full);
  margin-bottom: var(--space-4);
}

.cat-title {
  font-family: var(--font-serif);
  font-size: clamp(var(--text-4xl), 6vw, 5rem);
  font-weight: 700;
  line-height: 1.05;
  letter-spacing: -0.03em;
  color: var(--color-text);
  margin-bottom: var(--space-5);
}

.cat-subtitle {
  font-size: var(--text-lg);
  color: var(--color-text-muted);
  line-height: 1.7;
  max-width: 560px;
  margin-bottom: var(--space-6);
}

.cat-stats {
  font-size: var(--text-sm);
  color: var(--color-text-light);
  font-weight: 500;
}

.cat-grid-section { padding: var(--space-16) 0 var(--space-24); }

.cat-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--space-8);
}

.cat-empty {
  text-align: center;
  padding: var(--space-24) 0;
}
.cat-empty p {
  font-size: var(--text-lg);
  color: var(--color-text-muted);
  margin-bottom: var(--space-8);
}

.cat-cta {
  background: var(--color-border-light);
  padding: var(--space-16) 0;
  border-top: 1px solid var(--color-border);
}
.cat-cta-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-8);
}
.cat-cta-title {
  font-family: var(--font-serif);
  font-size: var(--text-2xl);
  font-weight: 700;
  letter-spacing: -0.02em;
  margin-bottom: var(--space-2);
}
.cat-cta-sub { font-size: var(--text-md); color: var(--color-text-muted); }

.btn-primary {
  background: var(--color-gruppi);
  box-shadow: 0 4px 20px rgba(8,145,178,.3);
}
.btn-primary:hover {
  background: var(--color-gruppi-dark);
  box-shadow: 0 6px 25px rgba(8,145,178,.4);
}

@media (max-width: 1024px) {
  .cat-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 768px) {
  .cat-hero { padding: var(--space-12) 0 var(--space-8); }
  .cat-grid { grid-template-columns: 1fr; }
  .cat-grid-section { padding: var(--space-10) 0 var(--space-16); }
  .cat-cta-inner { flex-direction: column; text-align: center; }
}
</style>
