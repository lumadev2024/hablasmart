---
/**
 * src/pages/index.astro
 * Homepage di HablaSmart.
 * Gli articoli in evidenza vengono letti dalle Content Collections.
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import PostCard    from '@/components/PostCard.astro';
import { getCollection } from 'astro:content';
import { readingTime }   from '@/utils/readingTime';

// ============================================================
// DATI ARTICOLI — Content Collections
// Prende i 3 articoli più recenti non in bozza
// ============================================================
const allPosts = await getCollection('blog', ({ data }) => !data.draft);

allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const featuredPosts = allPosts.slice(0, 3);

// Schema JSON-LD homepage
const homeSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      '@id': `${Astro.site}#website`,
      url: Astro.site,
      name: 'HablaSmart',
      description: 'Blog italiano su comunicazione comportamentale, psicologia della persuasione, marketing e AI applicata ai contenuti.',
      inLanguage: 'it-IT',
      potentialAction: {
        '@type': 'SearchAction',
        target: `${Astro.site}articoli/?q={search_term_string}`,
        'query-input': 'required name=search_term_string',
      },
    },
    {
      '@type': 'Blog',
      '@id': `${Astro.site}#blog`,
      name: 'HablaSmart',
      url: Astro.site,
      inLanguage: 'it-IT',
      publisher: { '@type': 'Organization', name: 'HablaSmart', url: Astro.site },
    },
    ...featuredPosts.map(post => ({
      '@type': 'BlogPosting',
      headline: post.data.title,
      description: post.data.description,
      url: `${Astro.site}articoli/${post.slug}/`,
      datePublished: post.data.pubDate.toISOString(),
      inLanguage: 'it-IT',
      author: { '@type': 'Organization', name: 'HablaSmart' },
    })),
  ],
});

// Pilastri editoriali
const pillars = [
  {
    icon: `<path d="M14 2C7.373 2 2 7.373 2 14s5.373 12 12 12 12-5.373 12-12S20.627 2 14 2zm0 4a4 4 0 110 8 4 4 0 010-8zm0 17.2a8.8 8.8 0 01-7.333-3.928C8.253 17.36 11.053 16.4 14 16.4c2.947 0 5.747.96 7.333 2.872A8.8 8.8 0 0114 23.2z" fill="currentColor"/>`,
    title:    'Comunicazione Comportamentale',
    hook:     'Capisci cosa le persone dicono davvero (anche quando non lo dicono).',
    desc:     'Segnali, sottotesto e dinamiche invisibili che guidano ogni interazione.',
    cta:      'Scopri come comunicare meglio',
    href:     '/articoli/?categoria=Comunicazione',
    label:    'comunicazione comportamentale',
    delay:    '0.1s',
    featured: false,
  },
  {
    icon: `<path d="M3 7h22v2H3V7zm0 6h22v2H3v-2zm0 6h14v2H3v-2z" fill="currentColor"/>`,
    title:    'Marketing con Psicologia',
    hook:     'Le persone non scelgono in modo razionale.',
    desc:     'Bias cognitivi e leve mentali applicate a contenuti e strategie che convertono.',
    cta:      'Migliora i tuoi risultati',
    href:     '/articoli/?categoria=Marketing',
    label:    'marketing e psicologia',
    delay:    '0.2s',
    featured: true,
  },
  {
    icon: `<path d="M14 2L3 8v12l11 6 11-6V8L14 2zm0 3.09L22.09 9.5 14 13.91 5.91 9.5 14 5.09zM5 11.44l8 4.37V23.5L5 19.13V11.44zm10 12.06v-7.69l8-4.37v7.69L15 23.5z" fill="currentColor"/>`,
    title:    'Psicologia della Persuasione',
    hook:     'Ogni decisione è influenzata da schemi mentali precisi.',
    desc:     'Impara come funzionano — e come usarli in modo consapevole.',
    cta:      'Capisci cosa influenza davvero',
    href:     '/articoli/?categoria=Persuasione',
    label:    'psicologia della persuasione',
    delay:    '0.3s',
    featured: false,
  },
  {
    icon: `<path d="M22 10h-4V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2h4v4l8-4h4a2 2 0 002-2v-6a2 2 0 00-2-2z" fill="currentColor"/>`,
    title:    'AI Applicata ai Contenuti',
    hook:     "L'AI non deve renderti più veloce. Deve renderti più efficace.",
    desc:     'Workflow e sistemi per creare contenuti che funzionano davvero.',
    cta:      "Usa l'AI con metodo",
    href:     '/articoli/?categoria=AI+%26+Contenuti',
    label:    'AI applicata ai contenuti',
    delay:    '0.4s',
    featured: false,
  },
];

// Passi del metodo
const steps = [
  { num: '01', title: 'Capisci', delay: '0.1s', desc: 'Parti da ciò che le persone fanno davvero, non da quello che dicono. Comportamenti reali, non teorie astratte.' },
  { num: '02', title: 'Analizza', delay: '0.2s', desc: 'Scomponiamo i meccanismi psicologici dietro ogni decisione. Solo ciò che conta davvero, senza semplificazioni inutili.' },
  { num: '03', title: 'Trasforma', delay: '0.3s', desc: 'Ogni insight diventa un framework concreto, pronto da usare subito nei tuoi contenuti e nella tua comunicazione.' },
  { num: '04', title: 'Ottimizza', delay: '0.4s', desc: 'Misuri, migliori e iteri. La comunicazione efficace non è fortuna: è metodo.' },
];
---

<BaseLayout>
  <!-- Schema JSON-LD iniettato nel <head> tramite slot -->
  <Fragment slot="head">
    <script type="application/ld+json" set:html={homeSchema} />
  </Fragment>

  <!-- ============================================================
       HERO
  ============================================================ -->
  <section class="hero" aria-labelledby="hero-heading">
    <div class="container hero-container">

      <div class="hero-content">
        <p class="hero-pretitle">
          Se le tue parole non funzionano,<br>non è colpa del messaggio.
        </p>
        <h1 id="hero-heading" class="hero-title">
          È che non capisci come<br>
          <em class="hero-accent">decidono le persone.</em>
        </h1>
        <p class="hero-subtitle">
          HablaSmart unisce psicologia, comunicazione e AI per trasformare i tuoi contenuti e messaggi in strumenti che influenzano davvero.
        </p>
        <div class="hero-actions">
          <a href="/articoli/" class="btn btn-primary btn-lg"
             aria-label="Inizia a leggere gli articoli">
            Inizia da qui
          </a>
          <a href="#newsletter" class="btn btn-ghost btn-lg"
             aria-label="Iscriviti alla newsletter settimanale">
            Newsletter settimanale
            <span class="btn-arrow" aria-hidden="true">→</span>
          </a>
        </div>
        <ul class="hero-micro-proof" aria-label="Cosa trovi su HablaSmart">
          <li><span class="mp-check" aria-hidden="true">✔</span> Framework pratici</li>
          <li><span class="mp-check" aria-hidden="true">✔</span> Psicologia applicata</li>
          <li><span class="mp-check" aria-hidden="true">✔</span> Zero fuffa</li>
        </ul>
      </div>

      <!-- Hero visual: video YouTube + chip flottanti -->
      <div class="hero-visual" aria-hidden="true">

        <!-- Video di sfondo -->
        <div class="hero-video-wrap">
          <iframe
            id="hero-yt-player"
            src="https://www.youtube.com/embed/KgGmqWmkqJU?autoplay=1&mute=1&loop=1&playlist=KgGmqWmkqJU&controls=0&rel=0&modestbranding=1&playsinline=1&enablejsapi=1"
            allow="autoplay; encrypted-media"
            loading="lazy"
            title="HablaSmart preview"
          ></iframe>
          <button id="hero-mute-btn" class="hero-video-mute-btn" aria-label="Attiva audio" title="Attiva audio">
            🔇
          </button>
        </div>

        <p class="hero-video-credit"><em>dal film Thank You for Smoking</em></p>

      </div>

    </div>
  </section>

  <!-- ============================================================
       PILASTRI
  ============================================================ -->
  <section class="pillars" aria-labelledby="pillars-heading" id="pillars">
    <div class="container">

      <header class="section-header reveal-up">
        <span class="section-label">Il metodo HablaSmart</span>
        <h2 id="pillars-heading" class="section-title">
          Non sono categorie.<br>È un sistema.
        </h2>
        <p class="section-subtitle">
          HablaSmart unisce psicologia, comportamento e AI per aiutarti
          a smettere di improvvisare e iniziare a comunicare con metodo.
        </p>
      </header>

      <div class="pillars-grid">
        {pillars.map(p => (
          <a
            href={p.href}
            class={`pillar-card reveal-up${p.featured ? ' pillar-card--featured' : ''}`}
            style={`--delay: ${p.delay}`}
            aria-label={`Leggi articoli su ${p.label}`}
          >
            <div class="pillar-icon" aria-hidden="true">
              <svg width="28" height="28" viewBox="0 0 28 28" fill="none" aria-hidden="true">
                <Fragment set:html={p.icon} />
              </svg>
            </div>
            <h3 class="pillar-title">{p.title}</h3>
            <p class="pillar-hook">{p.hook}</p>
            <p class="pillar-desc">{p.desc}</p>
            <span class="pillar-cta" aria-hidden="true">
              {p.cta} <span class="pillar-arrow">→</span>
            </span>
          </a>
        ))}
      </div>

    </div>
  </section>

  <!-- ============================================================
       ARTICOLI IN EVIDENZA — da Content Collections
  ============================================================ -->
  <section class="featured-posts" aria-labelledby="featured-heading" id="articoli">
    <div class="container">

      <header class="section-header reveal-up">
        <span class="section-label">Se parti da zero, inizia da questi</span>
        <h2 id="featured-heading" class="section-title">
          Inizia da qui.<br>
          <span class="section-title-sub">I contenuti che cambiano davvero come comunichi.</span>
        </h2>
        <p class="section-subtitle">
          Una selezione degli articoli più utili per capire psicologia,
          persuasione e contenuti — e applicarli subito.
        </p>
      </header>

      {featuredPosts.length > 0 ? (
        <div class="posts-grid">
          <!-- Primo articolo: card grande -->
          <PostCard
            post={featuredPosts[0]}
            variant="featured"
            readingTime={readingTime(featuredPosts[0].body)}
            artIndex={0}
            delay="0.1s"
            badge="Da leggere per primo"
          />

          <!-- Articoli secondari -->
          {featuredPosts.length > 1 && (
            <div class="posts-side">
              {featuredPosts.slice(1).map((post, i) => (
                <PostCard
                  post={post}
                  variant="compact"
                  readingTime={readingTime(post.body)}
                  artIndex={i + 1}
                  delay={`${(i + 2) * 0.1}s`}
                />
              ))}
            </div>
          )}
        </div>
      ) : (
        <p class="posts-empty">Nessun articolo ancora pubblicato. Torna presto!</p>
      )}

      <div class="posts-cta reveal-up">
        <a href="/articoli/" class="btn btn-outline"
           aria-label="Esplora tutti gli articoli del blog HablaSmart">
          Esplora tutti gli articoli <span aria-hidden="true">→</span>
        </a>
      </div>

    </div>
  </section>

  <!-- ============================================================
       METODO
  ============================================================ -->
  <section class="method" aria-labelledby="method-heading" id="metodo">
    <div class="container">

      <header class="section-header reveal-up">
        <span class="section-label">Il metodo HablaSmart</span>
        <h2 id="method-heading" class="section-title">
          Non è teoria.<br>
          <span class="section-title-sub">È un metodo per ottenere risultati reali.</span>
        </h2>
        <p class="section-subtitle">
          Ogni contenuto segue un sistema preciso: capire, interpretare e applicare
          la psicologia per migliorare davvero come comunichi.
        </p>
      </header>

      <ol class="method-steps" role="list">
        {steps.map(s => (
          <li class="method-step reveal-up" style={`--delay: ${s.delay}`}>
            <div class="step-number" aria-hidden="true">{s.num}</div>
            <div class="step-content">
              <h3 class="step-title">{s.title}</h3>
              <p class="step-desc">{s.desc}</p>
            </div>
          </li>
        ))}
      </ol>

      <p class="method-payoff reveal-up">
        È questo che trasforma contenuti in risultati.
      </p>

    </div>
  </section>

  <!-- ============================================================
       NEWSLETTER
  ============================================================ -->
  <section class="newsletter" aria-labelledby="newsletter-heading" id="newsletter">
    <div class="container">
      <div class="newsletter-inner reveal-up">

        <span class="newsletter-label">Ogni venerdì</span>

        <h2 id="newsletter-heading" class="newsletter-title">
          Se vuoi comunicare meglio, devi capire meglio.<br>
          <em class="newsletter-accent">Qui è dove inizi.</em>
        </h2>

        <p class="newsletter-subtitle">
          Ogni venerdì ricevi un'analisi chiara e applicabile su comunicazione,
          persuasione e AI. Solo contenuti che puoi usare davvero.
        </p>

        <!-- Social proof sopra il form -->
        <p class="newsletter-proof">
          Unisciti a <strong>2.4K+ lettori</strong> che vogliono comunicare meglio
          — tasso di apertura <strong>93%</strong>
        </p>

        <form
          class="newsletter-form"
          id="newsletter-form"
          action="#"
          method="POST"
          aria-label="Modulo iscrizione newsletter HablaSmart"
          novalidate
        >
          <div class="form-group">
            <label for="newsletter-email" class="sr-only">Indirizzo email</label>
            <input
              type="email"
              id="newsletter-email"
              name="email"
              class="form-input"
              placeholder="Dove vuoi ricevere gli insight?"
              required
              autocomplete="email"
              aria-required="true"
              aria-describedby="newsletter-privacy"
            />
            <button type="submit" class="btn btn-primary btn-lg form-submit"
                    aria-label="Ricevi il prossimo insight">
              Ricevi il prossimo insight
            </button>
          </div>
          <p id="newsletter-privacy" class="form-note">
            Iscrivendoti accetti la nostra
            <a href="/privacy/" class="form-link">Privacy Policy</a>.
          </p>
        </form>

        <!-- Micro-trust sotto il form -->
        <ul class="newsletter-trust" aria-label="Garanzie newsletter">
          <li><span aria-hidden="true">✔</span> 1 email a settimana</li>
          <li><span aria-hidden="true">✔</span> Zero spam</li>
          <li><span aria-hidden="true">✔</span> Disiscrizione in 1 click</li>
        </ul>

        <p class="newsletter-payoff">Leggi. Applica. Migliora.</p>

      </div>
    </div>
  </section>

</BaseLayout>

<!-- Newsletter form script -->
<script>
(function () {
  const form  = document.getElementById('newsletter-form') as HTMLFormElement | null;
  const input = document.getElementById('newsletter-email') as HTMLInputElement | null;
  if (!form || !input) return;

  let fb = document.getElementById('form-feedback');
  if (!fb) {
    fb = document.createElement('p');
    fb.id = 'form-feedback';
    fb.setAttribute('role', 'alert');
    fb.setAttribute('aria-live', 'polite');
    fb.style.cssText = 'margin-top:8px;font-size:.875rem;font-weight:600;text-align:center;min-height:20px';
    form.appendChild(fb);
  }

  const show = (msg: string, ok: boolean) => {
    fb!.textContent = msg;
    fb!.style.color = ok ? 'rgba(134,239,172,.9)' : 'rgba(252,165,165,.9)';
  };

  input.addEventListener('input', () => { fb!.textContent = ''; });

  form.addEventListener('submit', async e => {
    e.preventDefault();
    const email = input.value.trim();
    if (!email) { show('⚠ Inserisci il tuo indirizzo email.', false); input.focus(); return; }
    if (!/^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/.test(email)) { show("⚠ L'email non sembra valida.", false); input.focus(); return; }

    const btn = form.querySelector<HTMLButtonElement>('.form-submit')!;
    btn.disabled = true;
    btn.textContent = 'Iscrizione in corso…';

    try {
      const res = await fetch('/api/subscribe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email }),
      });
      const data = await res.json();

      if (res.ok) {
        input.value = '';
        show('✓ Iscrizione completata! Controlla la tua email.', true);
      } else if (res.status === 409) {
        show('ℹ Sei già iscritto con questa email.', false);
      } else {
        show(data.error ?? '✗ Qualcosa è andato storto. Riprova.', false);
      }
    } catch {
      show('✗ Errore di rete. Controlla la connessione e riprova.', false);
    } finally {
      btn.disabled = false;
      btn.textContent = 'Iscriviti ora';
    }
  });
})();
</script>

<!-- Hero video mute toggle -->
<script>
  const muteBtn = document.getElementById('hero-mute-btn');
  const ytFrame = document.getElementById('hero-yt-player') as HTMLIFrameElement | null;
  let muted = true;

  muteBtn?.addEventListener('click', () => {
    muted = !muted;
    const cmd = muted ? 'mute' : 'unMute';
    ytFrame?.contentWindow?.postMessage(
      JSON.stringify({ event: 'command', func: cmd, args: [] }), '*'
    );
    if (muteBtn) {
      muteBtn.textContent  = muted ? '🔇' : '🔊';
      muteBtn.title        = muted ? 'Attiva audio' : 'Disattiva audio';
      muteBtn.setAttribute('aria-label', muted ? 'Attiva audio' : 'Disattiva audio');
    }
  });
</script>

<style>
/* ============================================================
   HERO
============================================================ */
.hero {
  min-height: calc(100vh - var(--header-height));
  display: flex;
  align-items: center;
  padding: var(--space-20) 0;
  position: relative;
  overflow: hidden;
}

.hero::before {
  content: '';
  position: absolute;
  inset: 0;
  background-image:
    radial-gradient(circle at 20% 50%, rgba(124,58,237,.04) 0%, transparent 50%),
    radial-gradient(circle at 80% 20%, rgba(244,114,182,.04) 0%, transparent 50%);
  pointer-events: none;
}

.hero-container {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-16);
  align-items: center;
  position: relative;
  z-index: 1;
}

.hero-content {
  max-width: 560px;
  animation: fadeInUp .8s cubic-bezier(.16,1,.3,1) both .1s;
}

.hero-pretitle {
  font-family: var(--font-serif);
  font-size: clamp(var(--text-lg), 2.2vw, var(--text-xl));
  font-weight: 700;
  color: var(--color-text);
  line-height: 1.35;
  letter-spacing: -0.01em;
  margin-bottom: var(--space-3);
}

.hero-title {
  font-family: var(--font-serif);
  font-size: clamp(var(--text-3xl), 4.5vw, var(--text-4xl));
  line-height: 1.1;
  margin-bottom: var(--space-6);
  letter-spacing: -0.03em;
}

.hero-accent {
  font-style: italic;
  background: linear-gradient(135deg, var(--color-primary), var(--color-secondary));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.hero-subtitle {
  font-size: var(--text-base);
  color: var(--color-text-muted);
  line-height: 1.7;
  max-width: 480px;
  margin-bottom: var(--space-6);
}

.hero-actions {
  display: flex;
  align-items: center;
  gap: var(--space-4);
  flex-wrap: wrap;
  margin-bottom: var(--space-8);
}

.btn-arrow { display: inline-block; transition: transform var(--transition-base); }
.btn-ghost:hover .btn-arrow { transform: translateX(4px); }

.hero-micro-proof {
  display: flex;
  gap: var(--space-5);
  flex-wrap: wrap;
  list-style: none;
  padding: 0;
  margin: 0;
}

.hero-micro-proof li {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  font-size: var(--text-sm);
  font-weight: 600;
  color: var(--color-text-muted);
}

.mp-check {
  color: var(--color-primary);
  font-size: var(--text-xs);
}

/* ============================================================
   HERO VISUAL (CSS Art)
============================================================ */
.hero-visual {
  position: relative;
  height: 480px;
  animation: fadeIn 1s ease both .3s;
  border-radius: var(--radius-2xl);
  overflow: hidden;
}

.abstract-shape {
  position: absolute;
  border-radius: 50%;
}

.shape-1 {
  width: 320px; height: 320px;
  background: radial-gradient(circle, rgba(124,58,237,.12) 0%, rgba(124,58,237,.02) 70%);
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  animation: breathe 6s ease-in-out infinite;
}
.shape-2 {
  width: 200px; height: 200px;
  background: radial-gradient(circle, rgba(244,114,182,.15) 0%, transparent 70%);
  top: 10%; right: 5%;
  animation: drift 8s ease-in-out infinite;
}
.shape-3 {
  width: 140px; height: 140px;
  background: radial-gradient(circle, rgba(124,58,237,.1) 0%, transparent 70%);
  bottom: 10%; left: 5%;
  animation: drift 10s ease-in-out infinite reverse;
}

.abstract-grid {
  position: absolute;
  width: 280px; height: 280px;
  background-image:
    linear-gradient(rgba(124,58,237,.08) 1px, transparent 1px),
    linear-gradient(90deg, rgba(124,58,237,.08) 1px, transparent 1px);
  background-size: 28px 28px;
  border-radius: var(--radius-2xl);
  top: 50%; left: 50%;
  transform: translate(-50%,-50%) rotate(8deg);
}

/* ── Hero Chips ─────────────────────────────────────── */
.hero-video-credit {
  position: absolute;
  bottom: var(--space-4);
  left: var(--space-5);
  z-index: 3;
  font-size: var(--text-xs);
  color: rgba(255,255,255,0.55);
  text-shadow: 0 1px 4px rgba(0,0,0,0.4);
}

/* ============================================================
   PILLARS
============================================================ */
.pillars {
  padding: var(--space-32) 0;
}

.pillars-grid {
  display: grid;
  grid-template-columns: repeat(4,1fr);
  gap: var(--space-6);
}

.pillar-card {
  background: var(--color-surface);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-xl);
  padding: var(--space-8);
  transition: transform var(--transition-base), box-shadow var(--transition-base), border-color var(--transition-base);
  position: relative;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  text-decoration: none;
  color: inherit;
  cursor: pointer;
}

.pillar-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 3px;
  background: linear-gradient(90deg, var(--color-primary), var(--color-secondary));
  opacity: 0;
  transition: opacity var(--transition-base);
}

.pillar-card:hover {
  transform: translateY(-5px);
  box-shadow: var(--shadow-xl);
  border-color: var(--color-primary-light);
}
.pillar-card:hover::before { opacity: 1; }
.pillar-card:hover .pillar-arrow { transform: translateX(4px); }

/* Featured card */
